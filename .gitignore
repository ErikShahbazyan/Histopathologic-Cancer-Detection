# ── Data (download from Kaggle, never commit) ──────────
data/train/*
data/test/*
data/train_labels.csv
!data/train/.gitkeep
!data/test/.gitkeep

# ── Generated outputs (recreated on run) ───────────────
logs/*
outputs/*
!logs/.gitkeep
!outputs/.gitkeep

# ── Python cache ────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── OS junk ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Virtual environments ─────────────────────────────────
venv/
.venv/
env/

# ── IDE ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
